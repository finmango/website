{
  "name": "cgap-video",
  "private": true,
  "description": "FinMango CGAP pitch video build pipeline",
  "scripts": {
    "record": "node src/record-calculators.mjs",
    "music": "node src/generate-music.mjs",
    "prepare-timeline": "node src/prepare-timeline.mjs",
    "transcribe": "python3 src/transcribe-captions.py",
    "render": "remotion render src/index.ts Pitch output/finmango-cgap-pitch.mp4 --codec h264 --crf 19",
    "studio": "remotion studio src/index.ts",
    "build": "bash build.sh"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@remotion/cli": "^4.0.0",
    "playwright": "^1.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0",
    "zod": "^3.22.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "typescript": "^5.5.0"
  }
}